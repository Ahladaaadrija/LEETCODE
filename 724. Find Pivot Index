class Solution(object):
    def pivotIndex(self, nums):
        n = len(nums)
        prefix = [0]*n
        postfix = [0]*n
        prefix[0] = nums[0]
        postfix[n-1] = nums[n-1]
        for i in range(1,n):
           prefix[i] = prefix[i-1]+nums[i]
        for i in range(n-2,-1,-1):
            postfix[i] = postfix[i+1]+nums[i]
        for i in range(n):
            if i == 0:
                left = 0
            else:
                left = prefix[i - 1]

            if i == n - 1:
                right = 0
            else:
                right = postfix[i + 1]

            if left == right:
                return i
        return -1

