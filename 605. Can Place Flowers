class Solution(object):
    def canPlaceFlowers(self, flowerbed, n):
        count = 0
        m = len(flowerbed)
        for i in range(m):
            if i == 0:
                if flowerbed[i] == 0 and i + 1 < m:
                    if flowerbed[i+1] == 0:
                        flowerbed[i] = 1
                        count += 1
                elif flowerbed[i] == 0:
                    flowerbed[i] = 1
                    count += 1
            elif i < m-1:
                if flowerbed[i] == 0:
                    if flowerbed[i-1] == 0 and flowerbed[i+1] == 0:
                        flowerbed[i] = 1
                        count += 1
            else:
                if flowerbed[i] == 0:
                    if flowerbed[i-1] == 0:
                        flowerbed[i] = 1
                        count += 1
        if n <= count:
            return True
        else:
            return False
