class Solution(object):
    def isSubsequence(self, s, t):
        sl = list(s)
        tl = list(t)
        new = ""
        p = False
        st = 0
        for j in s:
            for i in range(st, len(tl)):
                if j == tl[i]:
                    new += j
                    st = i + 1
                    break    
                
                       
        print (new)
        if new == s:
            p = True
        return p
                            
                        





        
