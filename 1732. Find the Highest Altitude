class Solution(object):
    def largestAltitude(self, gain):
        n = len(gain)
        ans = []
        ans.append(0)
        out = gain[0]
        ans.append(out)
        for i in range(1,n):
            if i != n:
                out = out + gain[i]
                ans.append(out)
        out = max(ans)
        return out
