class Solution(object):
    def maxVowels(self, s, k):
        ss = "".join(s)
        output = 0
        i = 0
        e = k-1
        count = 0
        for j in range(i,k):
            if ss[j] in "aeiou":
                count += 1
        output = max(count,output)
        while e < len(s)-1:
            e = e+1
            i = i+1
            if ss[e] in "aeiou":
                count += 1

            
            if ss[i-1] in "aeiou":
                count -= 1
            output = max(count,output)
        return output


            
        
