class Solution(object):
    def uniqueOccurrences(self, arr):
        p = []
        s = []
        for i in arr:
            if i not in s:
                s.append(i)
                k = arr.count(i)
                p.append(k)
        for j in p:
            if p.count(j) > 1:
                return False
        return True
        
