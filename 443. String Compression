class Solution(object):
    def compress(self, chars):
        n = len(chars)
        i = 0
        j = 0 
        while j<n:
            count = 1
            chars[i] = chars[j]
            while j+1 < n and chars[j] == chars[j+1]:
                count += 1
                j += 1
            if count > 1:
                for c in str(count):
                    chars[i+1] = c
                    i += 1
            i += 1
            j += 1
        return i
