class Solution:
    def minSubArrayLen(self, target: int, nums: List[int]) -> int:
        left = 0
        summ = 0
        mini = float('inf')
        for right in range(len(nums)):
            summ += nums[right]
            while summ >= target:
                mini = min(mini, right - left + 1)
                summ -= nums[left]
                left += 1
        if mini == float('inf'):
            return 0
        else:
            return mini
