class Solution(object):
    def maxOperations(self, nums, k):
        nums.sort()
        count = 0
        s = 0
        i=0
        j=len(nums)-1
        while i<j:
            s = nums[i] + nums[j]
            if s<k:
                i+=1
            elif s == k:
                count += 1
                j -= 1
                i += 1
            else:
                j -= 1
        return count

        
