class Solution(object):
    def productExceptSelf(self, nums):
        n = len(nums)
        ans = [0] * n
        prefix = [1] * n
        postfix = [1] * n
        for i in range(n):
            if i == 0:
                prefix[i] = nums[i]
            else:
                prefix[i] = prefix[i-1] * nums[i]
        for i in range(n-1,0,-1):
            if i == n-1:
                postfix[i] = nums[i]
            else:
                postfix[i] = postfix[i+1] * nums[i]
        for i in range(n):
            if i == 0:
                ans[i] = postfix[i+1]
            elif i == (n-1):
                ans[i] = prefix[i-1]
            else:
                ans[i] = prefix[i-1] * postfix[i+1]
            
        return ans
