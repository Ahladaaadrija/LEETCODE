class Solution:
    def majorityElement(self, nums: List[int]) -> int:
        count = {}
        for i  in nums:
            if i not in count:
                c = nums.count(i)
                count[i] = c
        p = dict(sorted(count.items(),key = lambda x: x[1],reverse = True))
        j = list(p.keys())[0] 
        return j
            


        
