class Solution(object):
    def gcdOfStrings(self, str1, str2):
        if str2 > str1:
            str1, str2 = str2, str1
        
        sl = ""
        
        if str1 + str2 != str2 + str1:
            return ""
        else:
            str2_len = len(str2)
            str1_len = len(str1)
            
          
            def gcd(a, b):
                while b:
                    a, b = b, a % b
                return a
            
            length = gcd(str1_len, str2_len)
            sl = str1[:length]
        
        return sl
