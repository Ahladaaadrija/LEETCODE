for i in asteroids:
            while stack and i < 0 and stack[-1] > 0:
                if stack[-1] < abs(i):
                    stack.pop()
                elif stack[-1] == abs(i):
                    stack.pop()
                    i = 0
                    break
                else:
                    i = 0
                    break

            if i != 0:
                stack.append(i)

        return stack
